+def _workflow_gui_theme() -> str:
+    """Resolve an optional GUI theme override."""
+
+    value = os.getenv("PD_PKI_WEB_THEME", "").strip().lower()
+    return "dark" if value == "dark" else "system"
+
+
+def _workflow_gui_hide_cursor() -> bool:
+    """Resolve whether the GUI should explicitly hide the cursor."""
+
+    value = os.getenv("PD_PKI_WEB_HIDE_CURSOR", "").strip().lower()
+    return value in {"1", "true", "yes", "on"}
+
