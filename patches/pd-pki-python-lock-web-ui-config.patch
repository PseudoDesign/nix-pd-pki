 """
 
 
+_WORKFLOW_GUI_ENVIRONMENT = {
+    "workflowRoot": "PD_PKI_WEB_WORKFLOW_ROOT",
+    "profileDir": "PD_PKI_WEB_PROFILE_DIR",
+    "tokenDir": "PD_PKI_WEB_TOKEN_DIR",
+    "workspaceDir": "PD_PKI_WEB_WORKSPACE_DIR",
+    "bundleDir": "PD_PKI_WEB_BUNDLE_DIR",
+    "repositoryRoot": "PD_PKI_WEB_REPOSITORY_ROOT",
+    "rootName": "PD_PKI_WEB_ROOT_NAME",
+}
+
+
+def _locked_workflow_gui_config() -> dict[str, str] | None:
+    """Resolve optional, appliance-managed GUI settings from environment."""
+
+    lock_setting = os.getenv("PD_PKI_WEB_LOCK_CONFIG", "").strip().lower()
+    if lock_setting in {"0", "false", "no", "off"}:
+        return None
+
+    resolved = {
+        key: value
+        for key, env_name in _WORKFLOW_GUI_ENVIRONMENT.items()
+        if (value := os.getenv(env_name, "").strip())
+    }
+
+    required_keys = {
+        "profileDir",
+        "tokenDir",
+        "workspaceDir",
+        "bundleDir",
+        "repositoryRoot",
+        "rootName",
+    }
+    if not required_keys.issubset(resolved):
+        return None
+
+    if "workflowRoot" not in resolved:
+        resolved["workflowRoot"] = os.path.dirname(resolved["workspaceDir"]) or resolved["workspaceDir"]
+    return resolved
+
+
 def render_workflow_gui() -> HTMLResponse:
     """Return the single-page workflow GUI.
 
